    "routesDir": "src/routes",
    "libDir": "src/lib"
  },
  
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5"
  },
  
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  },
  
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
