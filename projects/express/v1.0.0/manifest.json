{
  "name": "express",
  "version": "1.0.0",
  "description": "Express.js + TypeScript API starter",
  "framework": "express",
  "frameworkVersion": "Express 4",
  "status": "stable",
  "category": "backend",
  "tags": ["express", "node", "api", "backend"],
  "aliases": ["express-api", "node-api"],
  
  "structure": {
