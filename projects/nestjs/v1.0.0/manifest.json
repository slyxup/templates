  "status": "stable",
  "category": "backend",
  "tags": ["nestjs", "node", "api", "backend", "enterprise"],
  "aliases": ["nest", "nest-api"],
  
  "structure": {
    "sourceDir": "src",
    "controllersDir": "src/controllers",
    "servicesDir": "src/services"
  },
  
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  },
  
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main"
