{
  "name": "graphql",
  "version": "1.0.0",
  "description": "GraphQL Server with Apollo Server v4",
  "framework": "apollo-server",
  "frameworkVersion": "Apollo Server 4",
  "status": "stable",
  "category": "backend",
  "tags": ["graphql", "apollo", "api", "backend"],
  "aliases": ["apollo", "graphql-api"],
  
  "structure": {
    "sourceDir": "src",
    "schemaDir": "src/schema"
  },
  
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "graphql": "^16.8.1",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  },
  
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  }
}
